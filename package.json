{
  "name": "jhc-honey-chatbot-v2",
  "version": "2.0.0",
  "description": "J Health Care Honey CS 챗봇 v2 — 카카오톡 채널 + ChromaDB + AI API 미사용",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "server": "node src/api/server.js",
    "chromadb": "chroma run --path ./data/chromadb --port 8000",
    "index-kb": "node scripts/index-kb.js",
    "kb:stats": "node scripts/validate-kb.js",
    "report": "node scripts/generate-report.js",
    "tunnel": "ngrok http 3000",
    "test": "node --test tests/integration.test.js",
    "test:watch": "node --test --watch tests/integration.test.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "chat": "node src/index.js --mode=cli",
    "dashboard": "node src/api/dashboard-server.js",
    "dashboard:dev": "node --watch src/api/dashboard-server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "node-sqlite3-wasm": "^0.8.57",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "JHC Dev Team (CoT/ToT 20인 협의)",
  "license": "PRIVATE"
}
