# ── JHC Honey 챗봇 v2 환경변수 ──
# 이 파일을 .env 로 복사 후 실제 값 입력
# AI API 키 불필요 — 무료 로컬 엔진 사용

# ── 서버 설정 ──
PORT=3000
NODE_ENV=development

# ── 카카오톡 채널 설정 (무료) ──
# business.kakao.com 에서 발급
KAKAO_CHANNEL_ID=_xxxxx                    # 카카오톡 채널 ID
KAKAO_CHANNEL_SECRET=your_channel_secret   # 채널 시크릿 키
KAKAO_WEBHOOK_VERIFY_TOKEN=jhc_honey_2026  # Webhook 검증 토큰

# ── ChromaDB 설정 (무료 로컬) ──
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_PATH=./data/chromadb

# ── SQLite DB ──
SQLITE_PATH=./data/jhc_chatbot.db

# ── 검색 엔진 설정 ──
SEARCH_MIN_SCORE=0.05          # 최소 유사도 (0~1)
SEARCH_TOP_K=3                 # 상위 K개 결과
TFIDF_EXACT_BONUS=2.0          # 완전 일치 가중치
TFIDF_KEYWORD_BONUS=1.5        # 키워드 매칭 가중치

# ── 챗봇 설정 ──
BOT_NAME=Honey
COMPANY_NAME=J Health Care
ESCALATION_AVG_MIN=3           # 에스컬 평균 응답 시간(분)

# ── 캐시 설정 ──
CACHE_TTL_SECONDS=300          # 응답 캐시 유지 시간
CACHE_MAX_KEYS=1000            # 최대 캐시 키 수

# ── 로그 설정 ──
LOG_LEVEL=info
LOG_PATH=./logs

# ── 운영 설정 ──
MAX_MESSAGE_LENGTH=200         # 카카오톡 최대 글자 수
RATE_LIMIT_WINDOW_MS=60000     # Rate limit 윈도우 (1분)
RATE_LIMIT_MAX=30              # Rate limit 최대 요청 수
